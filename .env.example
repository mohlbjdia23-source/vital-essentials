# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/vital-essentials

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Stripe (client) — prefix with VITE_ so Vite exposes it to the browser ───
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── AliExpress / supplier ────────────────────────────────────────────────────
# Obtain these from the AliExpress Open Platform (https://developers.aliexpress.com/)
ALIEXPRESS_APP_KEY=your_app_key
ALIEXPRESS_APP_SECRET=your_app_secret
ALIEXPRESS_ACCESS_TOKEN=your_access_token
# Tracking / fulfillment currency and locale
SUPPLIER_CURRENCY=USD
SUPPLIER_LOCALE=en_US
SUPPLIER_SHIP_TO_COUNTRY=US

# ─── Email (optional – order confirmation emails) ────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=Vital Essentials <no-reply@example.com>
